# ---- circle-fe environment ----
# Copy to .env.local for development. In production (e.g. Vercel) set these in the
# host's Environment Variables, not in a file.

# Backend API origin. REQUIRED in production because the backend is on a separate
# domain. Set to the full API URL, e.g. https://api.yourdomain.com  (no trailing slash).
# Leave blank for local dev — the app then auto-derives http://<host>:8000 so it
# works on localhost and over the LAN/mobile. Leave blank in prod ONLY if the API
# is reverse-proxied under the same web domain at /api.
NEXT_PUBLIC_API_URL=https://api.example.com

# Optional: override the dev backend port used for LAN auto-derivation (default 8000).
# NEXT_PUBLIC_API_PORT=8000

# Google Drive Picker (resume import). Leave blank to hide the Drive button.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
NEXT_PUBLIC_GOOGLE_API_KEY=

# Recruitment Calendar embed (shared HR calendar address + optional TZ).
NEXT_PUBLIC_GOOGLE_CALENDAR_SRC=
NEXT_PUBLIC_GOOGLE_CALENDAR_TZ=Asia/Kolkata
